{
  "name": "lunchbot",
  "version": "0.0.3",
  "description": "informs about the daily lunch menus in Pasila",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "normalize:menus": "node scripts/normalize-menus.js",
    "refresh:menus": "node -e \"require('./services/menuRefresh').runFullMenuRefresh().then(()=>console.log('Refresh complete')).catch((err)=>{console.error(err);process.exit(1);})\""
  },
  "engines": {
    "node": "18.x"
  },
  "keywords": [],
