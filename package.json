  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@slack/web-api": "^7.0.2",
    "cheerio": "^1.0.0-rc.3",
    "dotenv": "^8.6.0",
    "express": "^4.19.1",
    "xml2js": "^0.6.2"
  }
}
